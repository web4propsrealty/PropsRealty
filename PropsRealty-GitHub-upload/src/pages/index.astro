---
import '../styles/global.css';

const googleScriptUrl = import.meta.env.PUBLIC_GOOGLE_SCRIPT_URL || '';
---

<!doctype html>
<html lang="en">
  <head>
    <meta charset="UTF-8" />
    <meta name="viewport" content="width=device-width" />
    <meta name="description" content="Props Realty Inc. is building a new digital experience. Contact our St. Thomas real estate team today." />
    <meta name="theme-color" content="#080d10" />
    <link rel="icon" type="image/png" href="/favicon.png" />
    <link rel="preconnect" href="https://fonts.googleapis.com" />
    <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin />
    <link href="https://fonts.googleapis.com/css2?family=Cormorant+Garamond:wght@500;600;700&family=Manrope:wght@400;500;600;700&display=swap" rel="stylesheet" />
    <title>Coming Soon | Props Realty Inc.</title>
  </head>
  <body class="hero-bg min-h-screen bg-[#080d10] text-white antialiased">
    <main class="flex min-h-screen items-center justify-center px-4 py-8 sm:px-6 sm:py-12">
      <section class="glass w-full max-w-5xl overflow-hidden rounded-[1.75rem] border border-white/12 px-5 py-7 sm:px-10 sm:py-10 lg:px-14" aria-labelledby="page-title">
        <div class="mx-auto max-w-3xl text-center">
          <div class="mb-5 flex items-center justify-center gap-3 text-gold">
            <span class="h-px w-10 bg-gold/60"></span>
            <span class="text-[.64rem] font-semibold uppercase tracking-[.36em]">A new address is coming</span>
            <span class="h-px w-10 bg-gold/60"></span>
          </div>
          <h1 id="page-title" class="sr-only">Props Realty Inc.</h1>
          <div class="mx-auto max-w-[270px] rounded-2xl bg-white p-3 shadow-xl shadow-black/20 sm:max-w-[340px] sm:p-4">
            <img src="/images/props-logo.png" alt="Props Realty Inc." class="h-auto w-full" />
          </div>
          <p class="mx-auto mt-4 max-w-xl text-sm leading-6 text-white/68 sm:text-base">Our new digital experience is currently under construction.</p>
        </div>

        <div class="mx-auto mt-7 grid max-w-2xl grid-cols-2 gap-4 sm:mt-9 sm:gap-10">
          <article class="text-center">
            <div class="portrait mx-auto aspect-[4/5] w-full max-w-[150px] overflow-hidden rounded-t-full bg-white/5 sm:max-w-[190px]">
              <img src="/images/jax-robinson.jpg" alt="Jax Robinson, Broker of Record" class="h-full w-full object-cover" onerror="this.style.display='none';this.nextElementSibling.style.display='grid'" />
              <div class="hidden h-full place-items-center bg-gradient-to-b from-white/12 to-white/3 font-serif text-4xl text-gold">JR</div>
            </div>
            <h2 class="mt-4 font-serif text-xl font-semibold sm:text-2xl">Jax Robinson</h2>
            <p class="mt-1 text-[.62rem] font-semibold uppercase tracking-[.19em] text-gold sm:text-xs">Broker of Record</p>
          </article>
          <article class="text-center">
            <div class="portrait mx-auto aspect-[4/5] w-full max-w-[150px] overflow-hidden rounded-t-full bg-white/5 sm:max-w-[190px]">
              <img src="/images/mario-longo.png" alt="Mario Longo, Salesperson" class="h-full w-full object-cover object-top" onerror="this.style.display='none';this.nextElementSibling.style.display='grid'" />
              <div class="hidden h-full place-items-center bg-gradient-to-b from-white/12 to-white/3 font-serif text-4xl text-gold">ML</div>
            </div>
            <h2 class="mt-4 font-serif text-xl font-semibold sm:text-2xl">Mario Longo</h2>
            <p class="mt-1 text-[.62rem] font-semibold uppercase tracking-[.19em] text-gold sm:text-xs">Salesperson</p>
          </article>
        </div>

        <div class="mx-auto mt-8 flex max-w-2xl flex-col items-center justify-between gap-5 border-t border-white/10 pt-6 sm:flex-row">
          <div class="text-center sm:text-left">
            <p class="text-[.65rem] font-semibold uppercase tracking-[.25em] text-white/45">Call us at</p>
            <a href="tel:+15196332000" class="mt-1 inline-block font-serif text-2xl font-semibold tracking-wide transition hover:text-gold focus-visible:outline-2 focus-visible:outline-offset-4 focus-visible:outline-gold sm:text-3xl">519-633-2000</a>
          </div>
          <button id="open-modal" class="rounded-full bg-gold px-7 py-3.5 text-xs font-bold uppercase tracking-[.18em] text-[#101416] transition hover:-translate-y-0.5 hover:bg-[#dfc38b] focus-visible:outline-2 focus-visible:outline-offset-4 focus-visible:outline-white">Notify me</button>
        </div>
      </section>
    </main>

    <dialog id="notify-dialog" class="m-auto w-[calc(100%-2rem)] max-w-lg rounded-3xl border border-white/12 bg-[#11181c] p-0 text-white shadow-2xl">
      <form id="notify-form" class="p-6 sm:p-8" data-endpoint={googleScriptUrl}>
        <div class="flex items-start justify-between gap-5">
          <div>
            <p class="text-[.65rem] font-bold uppercase tracking-[.25em] text-gold">Stay in the know</p>
            <h2 class="mt-2 font-serif text-3xl font-semibold">Be the first to hear.</h2>
          </div>
          <button id="close-modal" type="button" aria-label="Close form" class="grid size-9 shrink-0 place-items-center rounded-full border border-white/15 text-xl text-white/65 hover:text-white">×</button>
        </div>
        <p class="mt-2 text-sm leading-6 text-white/55">Tell us how we can help and we’ll be in touch.</p>
        <div class="mt-6 grid gap-4 sm:grid-cols-2">
          <label class="text-xs font-semibold text-white/70">Name<input required name="name" autocomplete="name" class="mt-2 w-full rounded-xl border border-white/12 bg-white/6 px-4 py-3 text-sm outline-none transition focus:border-gold" /></label>
          <label class="text-xs font-semibold text-white/70">Phone<input required name="phone" type="tel" autocomplete="tel" class="mt-2 w-full rounded-xl border border-white/12 bg-white/6 px-4 py-3 text-sm outline-none transition focus:border-gold" /></label>
          <label class="text-xs font-semibold text-white/70 sm:col-span-2">Email<input required name="email" type="email" autocomplete="email" class="mt-2 w-full rounded-xl border border-white/12 bg-white/6 px-4 py-3 text-sm outline-none transition focus:border-gold" /></label>
        </div>
        <fieldset class="mt-5">
          <legend class="text-xs font-semibold text-white/70">You are wanting to</legend>
          <div class="mt-3 flex gap-5">
            <label class="flex items-center gap-2.5 text-sm"><input name="interest" value="Buy" type="checkbox" class="size-4 accent-[#e22b2f]" /> Buy</label>
            <label class="flex items-center gap-2.5 text-sm"><input name="interest" value="Sell" type="checkbox" class="size-4 accent-[#e22b2f]" /> Sell</label>
          </div>
        </fieldset>
        <button type="submit" class="mt-7 w-full rounded-xl bg-gold px-6 py-3.5 text-xs font-bold uppercase tracking-[.18em] text-[#101416] hover:bg-[#dfc38b]">Subscribe</button>
        <p id="form-status" role="status" class="mt-3 min-h-5 text-center text-xs text-white/55"></p>
      </form>
    </dialog>

    <script>
      const dialog = document.querySelector<HTMLDialogElement>('#notify-dialog');
      const openButton = document.querySelector<HTMLButtonElement>('#open-modal');
      const closeButton = document.querySelector<HTMLButtonElement>('#close-modal');
      const form = document.querySelector<HTMLFormElement>('#notify-form');
      const status = document.querySelector<HTMLElement>('#form-status');
      openButton?.addEventListener('click', () => dialog?.showModal());
      closeButton?.addEventListener('click', () => dialog?.close());
      dialog?.addEventListener('click', (event) => { if (event.target === dialog) dialog.close(); });
      form?.addEventListener('submit', async (event) => {
        event.preventDefault();
        const interests = [...form.querySelectorAll<HTMLInputElement>('input[name="interest"]:checked')];
        if (!interests.length) { if (status) status.textContent = 'Please choose Buy, Sell, or both.'; return; }
        const endpoint = form.dataset.endpoint;
        if (!endpoint) { if (status) status.textContent = 'Thanks! The signup connection will be available soon.'; return; }
        const data = new FormData(form);
        data.set('interest', interests.map((item) => item.value).join(', '));
        if (status) status.textContent = 'Submitting…';
        try {
          await fetch(endpoint, { method: 'POST', body: data, mode: 'no-cors' });
          form.reset(); if (status) status.textContent = 'Thank you — we’ll be in touch.';
        } catch { if (status) status.textContent = 'Something went wrong. Please call us instead.'; }
      });
    </script>
  </body>
</html>
